{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/extension",
    "rootDir": "src",
    "incremental": true,
    "types": ["node", "vscode"],
    "noEmit": false,
    "tsBuildInfoFile": "dist/extension/.tsbuildinfo"
  },
  "include": ["src/extension/**/*.ts", "src/shared/**/*.ts"]
}
