{
  "name": "maden",
  "displayName": "Maden",
  "description": "Notion-like Markdown editor for VS Code",
  "version": "0.0.1",
  "private": true,
  "publisher": "alialek",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alialek/maden.git"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:maden.plateMarkdownEditor"
  ],
  "main": "./dist/extension/extension/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "maden.plateMarkdownEditor",
        "displayName": "Maden Markdown",
        "selector": [
          {
            "scheme": "file",
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Maden",
      "properties": {
        "maden.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI actions in the Plate editor."
        },
        "maden.liveWriteDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "description": "Debounce delay in milliseconds before writing webview changes to Markdown files."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p tsconfig.extension.json --pretty false",
    "build:webview": "vite build",
    "build:webview:dev": "vite build --mode development",
    "watch:extension": "tsc -w -p tsconfig.extension.json --pretty false",
    "watch:webview": "vite build --watch --mode development",
    "dev:webview": "vite",
    "typecheck": "npm run typecheck:extension && npm run typecheck:webview",
    "typecheck:extension": "tsc -p tsconfig.extension.json --noEmit --pretty false",
    "typecheck:webview": "tsc -p tsconfig.json --noEmit --pretty false",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/react": "^2.0.28",
    "@ariakit/react": "^0.4.22",
    "@emoji-mart/data": "^1.2.1",
    "@faker-js/faker": "^10.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@platejs/ai": "^52.3.1",
    "@platejs/autoformat": "^52.0.11",
    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/basic-styles": "^52.0.11",
    "@platejs/callout": "^52.0.11",
    "@platejs/caption": "^52.0.11",
    "@platejs/code-block": "^52.0.11",
    "@platejs/code-drawing": "^52.3.0",
    "@platejs/combobox": "^52.0.15",
    "@platejs/comment": "^52.0.11",
    "@platejs/date": "^52.0.11",
    "@platejs/dnd": "^52.0.11",
    "@platejs/docx": "^52.0.11",
    "@platejs/docx-io": "^52.2.0",
    "@platejs/emoji": "^52.0.15",
    "@platejs/excalidraw": "^52.0.11",
    "@platejs/floating": "^52.0.11",
    "@platejs/indent": "^52.0.11",
    "@platejs/juice": "^52.0.11",
    "@platejs/layout": "^52.0.11",
    "@platejs/link": "^52.0.11",
    "@platejs/list": "^52.0.11",
    "@platejs/markdown": "^52.3.1",
    "@platejs/math": "^52.0.11",
    "@platejs/media": "^52.0.11",
    "@platejs/mention": "^52.0.15",
    "@platejs/resizable": "^52.0.11",
    "@platejs/selection": "^52.0.16",
    "@platejs/slash-command": "^52.0.15",
    "@platejs/suggestion": "^52.0.11",
    "@platejs/table": "^52.0.11",
    "@platejs/toc": "^52.0.11",
    "@platejs/toggle": "^52.0.11",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@udecode/cn": "^52.0.11",
    "ai": "^5.0.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dedent": "^1.0.0",
    "html2canvas-pro": "^2.0.2",
    "lodash": "^4.17.23",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "pdf-lib": "^1.17.1",
    "platejs": "^52.3.2",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.3.1",
    "react-lite-youtube-embed": "^3.5.1",
    "react-player": "^3.3.1",
    "react-textarea-autosize": "^8.5.9",
    "react-tweet": "^3.3.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar-hide": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "use-file-picker": "^2.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.95.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.9"
  }
}
