{
  "name": "maden",
  "displayName": "Maden",
  "description": "Notion-like Markdown editor for VS Code using Plate",
  "version": "0.0.1",
  "private": true,
  "publisher": "alek",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:maden.plateMarkdownEditor"
  ],
  "main": "./dist/extension/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "maden.plateMarkdownEditor",
        "displayName": "Maden Markdown",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "Maden",
      "properties": {
        "maden.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI actions in the Plate editor."
        },
        "maden.liveWriteDebounceMs": {
          "type": "number",
          "default": 300,
          "minimum": 50,
          "description": "Debounce delay in milliseconds before writing webview changes to Markdown files."
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "tsc -p tsconfig.extension.json",
    "build:webview": "vite build",
    "watch:extension": "tsc -w -p tsconfig.extension.json",
    "watch:webview": "vite build --watch",
    "dev:webview": "vite",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:integration": "node ./scripts/run-integration-tests.mjs",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@platejs/basic-nodes": "^52.0.11",
    "@platejs/basic-styles": "^52.0.11",
    "@platejs/markdown": "^52.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "platejs": "^52.3.2",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.95.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.0.9"
  }
}
