{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Maden Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension/**/*.js"
      ],
      "preLaunchTask": "build"
    },
    {
      "name": "Run Maden Extension (Watchers Running)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension/**/*.js"
      ]
    }
  ]
}
